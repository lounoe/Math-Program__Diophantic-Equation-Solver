import tkinter as tk
from tkinter import messagebox
from math import gcd

class DiofanticaApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Solver de Ecuaciones Diofánticas")
        
        # Configurar tamaño de la ventana
        self.root.geometry("500x550")
        self.root.configure(bg="#78fab5")
        
        # Variables para los coeficientes
        self.a_var = tk.StringVar()
        self.b_var = tk.StringVar()
        self.c_var = tk.StringVar()
        
        # Configurar fuentes de Tkinter
        self.fuente_titulo = ("Calibri", 14, "bold")
        self.fuente_label = ("Arial", 12)
        self.fuente_entry = ("Consolas", 12)  # Fuente para números
        self.fuente_boton = ("Arial", 11, "bold")
        self.fuente_resultado = ("Courier New", 10)
        
        # Crear interfaz
        self.create_widgets()
    
    def create_widgets(self):
        # Frame principal
        main_frame = tk.Frame(self.root, padx=20, pady=20, bg="#78fab5")
        main_frame.pack(expand=True, fill="both")
        
        # Título
        tk.Label(main_frame, text="Ecuación de la forma: ax + by = c", 
                font=self.fuente_titulo, bg="#78fab5", fg="#1a5d3a").grid(row=0, columnspan=3, pady=10)
        
        # Entradas
        tk.Label(main_frame, text="a :", font=self.fuente_label, bg="#78fab5").grid(row=1, column=0, sticky="e", padx=5, pady=5)
        entry_a = tk.Entry(main_frame, textvariable=self.a_var, width=15, font=self.fuente_entry)
        entry_a.grid(row=1, column=1, padx=5, pady=5)
        
        tk.Label(main_frame, text="b :", font=self.fuente_label, bg="#78fab5").grid(row=2, column=0, sticky="e", padx=5, pady=5)
        entry_b = tk.Entry(main_frame, textvariable=self.b_var, width=15, font=self.fuente_entry)
        entry_b.grid(row=2, column=1, padx=5, pady=5)
        
        tk.Label(main_frame, text="c :", font=self.fuente_label, bg="#78fab5").grid(row=3, column=0, sticky="e", padx=5, pady=5)
        entry_c = tk.Entry(main_frame, textvariable=self.c_var, width=15, font=self.fuente_entry)
        entry_c.grid(row=3, column=1, padx=5, pady=5)
        
        # Botón de cálculo
        tk.Button(main_frame, text="Calcular Soluciones", 
                 font=self.fuente_boton,
                 command=self.calcular_soluciones, 
                 bg="#4CAF50", fg="white",
                 activebackground="#45a049",
                 cursor="hand2").grid(row=4, columnspan=3, pady=20)
        
        # Área de resultados con scrollbar
        resultado_frame = tk.Frame(main_frame)
        resultado_frame.grid(row=5, columnspan=3, sticky="nsew", pady=10)
        
        self.resultado_text = tk.Text(resultado_frame, height=12, width=50, 
                                     state="disabled", 
                                     font=self.fuente_resultado,
                                     wrap="word",
                                     bg="#ffffff", fg="#000000")
        self.resultado_text.pack(side="left", fill="both", expand=True)
        
        # Barra de desplazamiento
        scrollbar = tk.Scrollbar(resultado_frame, command=self.resultado_text.yview)
        scrollbar.pack(side="right", fill="y")
        self.resultado_text.config(yscrollcommand=scrollbar.set)
        
        # Configurar el grid para que sea responsivo
        main_frame.grid_rowconfigure(5, weight=1)
        main_frame.grid_columnconfigure(1, weight=1)
    
    def calcular_soluciones(self):
        try:
            a = int(self.a_var.get())
            b = int(self.b_var.get())
            c = int(self.c_var.get())
            
            # Limpiar resultados anteriores
            self.resultado_text.config(state="normal")
            self.resultado_text.delete(1.0, tk.END)
            
            # Verificar si hay solución
            d = gcd(a, b)
            if c % d != 0:
                self.resultado_text.insert(tk.END, "❌ No existen soluciones enteras.\n")
                self.resultado_text.insert(tk.END, f"Porque {d} (mcd de {a} y {b}) no divide a {c}.")
                self.resultado_text.config(state="disabled")
                return
            
            # Encontrar una solución particular
            x0, y0 = self.find_particular_solution(a, b, c)
            
            # Mostrar solución general
            self.resultado_text.insert(tk.END, "✅ SOLUCIÓN GENERAL:\n\n", "bold")
            self.resultado_text.insert(tk.END, f"x = {x0} + {b//d}k\n")
            self.resultado_text.insert(tk.END, f"y = {y0} - {a//d}k\n\n")
            self.resultado_text.insert(tk.END, "donde k es cualquier número entero.\n\n")
            
            # Mostrar algunas soluciones particulares
            self.resultado_text.insert(tk.END, "📊 ALGUNAS SOLUCIONES PARTICULARES:\n\n")
            for k in range(-3, 4):
                x = x0 + (b//d)*k
                y = y0 - (a//d)*k
                self.resultado_text.insert(tk.END, f"k = {k:2d}  →  x = {x:4d}, y = {y:4d}\n")
            
            self.resultado_text.config(state="disabled")
            
        except ValueError:
            messagebox.showerror("Error", "Por favor ingrese valores enteros válidos.")
        except Exception as e:
            messagebox.showerror("Error", f"Ha ocurrido un error: {str(e)}")
    
    def find_particular_solution(self, a, b, c):
        """Encuentra una solución particular usando el algoritmo extendido de Euclides"""
        def extended_gcd(a, b):
            if b == 0:
                return (a, 1, 0)
            else:
                g, x, y = extended_gcd(b, a % b)
                return (g, y, x - (a // b) * y)
        
        d, x, y = extended_gcd(a, b)
        k = c // d
        return (x * k, y * k)

if __name__ == "__main__":
    root = tk.Tk()
    app = DiofanticaApp(root)
    root.mainloop()